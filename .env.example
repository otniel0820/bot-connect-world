# ============================================================
# CONFIGURACION DEL BOT - CONECTA TUS API KEYS AQUI
# Copia este archivo como .env y rellena los valores
# ============================================================

# ---- FACEBOOK / META ----
# Token de acceso de tu página de Facebook
# Obtenlo en: Meta for Developers > Tu App > Messenger > Configuración > Tokens de acceso
META_PAGE_ACCESS_TOKEN=

# Token de verificación del webhook (puedes poner cualquier string secreto)
# Debes usar el mismo valor al configurar el webhook en Meta for Developers
META_VERIFY_TOKEN=

# App Secret de tu app de Meta
# Obtenlo en: Meta for Developers > Tu App > Configuración > Básica > Clave secreta
META_APP_SECRET=

# ---- OPENAI ----
# Obtenlo en: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo de OpenAI a usar (gpt-4o recomendado para soporte de visión)
OPENAI_MODEL=gpt-4o

# ---- STRIPE ----
# Clave secreta de Stripe
# Obtenla en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Secreto del webhook de Stripe
# Lo obtienes al crear el webhook en: https://dashboard.stripe.com/webhooks
# Configura el endpoint como: https://tudominio.com/webhook/stripe
# Eventos a escuchar: payment_intent.succeeded, checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- PANEL IPTV ----
PANEL_URL=http://tu-panel.com/login.php
PANEL_USERNAME=
PANEL_PASSWORD=
PANEL_LOGIN_KEY=

# ---- CONFIGURACION DE LA APP ----
PORT=3000
NODE_ENV=development

# ---- MODO PRUEBA ----
# Si está definido, el bot SOLO responde a este Facebook User ID (ideal para testing)
# Déjalo vacío o elimina la línea para que responda a todos
TEST_USER_ID=
